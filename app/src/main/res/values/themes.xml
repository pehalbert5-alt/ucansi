<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Ucansi" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Fond de l'écran splash -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <!-- Icône de l'écran splash -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Thème à appliquer après le splash -->
        <item name="postSplashScreenTheme">@style/Theme.Ucansi</item>
    </style>
</resources>